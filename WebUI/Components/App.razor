@using Microsoft.AspNetCore.Components.Authorization
@using WebUI.Services
@inject CustomAuthStateProvider AuthState

<CascadingAuthenticationState>
    @if (AuthState.IsInitializing)
    {
        <div class="loading-container" style="height: 100vh; display: flex; align-items: center; justify-content: center;">
            <div style="text-align: center;">
                <span class="spinner-large" style="border-top-color: #6366f1;"></span>
                <p style="margin-top: 16px; color: #94a3b8; font-family: sans-serif;">Memuat sesi...</p>
            </div>
        </div>
    }
    else
    {
        <Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                    <NotAuthorized>
                        @if (!context.User.Identity?.IsAuthenticated ?? true)
                        {
                            <RedirectToLogin />
                        }
                        else
                        {
                            <p class="text-danger">Anda tidak memiliki akses ke halaman ini.</p>
                        }
                    </NotAuthorized>
                </AuthorizeRouteView>
            </Found>
            <NotFound>
                <LayoutView Layout="@typeof(Layout.MainLayout)">
                    <p role="alert">Halaman tidak ditemukan.</p>
                </LayoutView>
            </NotFound>
        </Router>
    }
</CascadingAuthenticationState>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.TryInitializeAsync();
            StateHasChanged();
        }
    }
}
